rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'plan']) &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 128 &&
             data.plan in ['free', 'pro', 'premium'];
    }

    function isValidSubject(data) {
      return data.keys().hasAll(['subjectName', 'color', 'totalClasses', 'attendedClasses']) &&
             data.subjectName is string && data.subjectName.size() <= 100 &&
             data.color is string && data.color.size() <= 20;
    }

    // 1. User Profiles & Sub-resources
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) &&
                    incoming().email == existing().email; // Email is immutable

      match /subjects/{subjectId} {
        allow list, get: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidSubject(incoming());
        allow delete: if isOwner(userId);
      }

      match /timetable/{entryId} {
        allow read, write: if isOwner(userId);
      }

      match /assignments/{assignmentId} {
        allow read, write: if isOwner(userId);
      }

      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId);
      }

      match /faculty/{facultyId} {
        allow read, write: if isOwner(userId);
      }

      match /practicals/{practicalId} {
        allow read, write: if isOwner(userId);
      }
    }

    // 2. Collaborative Groups
    match /groups/{groupId} {
      // Basic rules for demo/academic app - members can read, admin can manage
      allow create: if isSignedIn();
      allow get: if isSignedIn(); // Allow get for joining
      allow list: if isSignedIn(); // In a real app we would lock this down more
      allow update: if isSignedIn(); // Simplify for the join logic
      allow delete: if isSignedIn() && existing().adminId == request.auth.uid;
    }
  }
}
