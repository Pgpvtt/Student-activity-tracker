rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'plan', 'userId', 'createdAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 128 &&
             data.plan in ['free', 'pro', 'premium'] &&
             data.userId is string &&
             data.createdAt is string;
    }

    function isValidSubject(data) {
      return data.keys().hasAll(['subjectName', 'color', 'totalClasses', 'attendedClasses']) &&
             data.subjectName is string && data.subjectName.size() <= 100 &&
             data.color is string && data.color.size() <= 20 &&
             data.totalClasses is int && data.attendedClasses is int;
    }

    // 1. User Profiles & Sub-resources
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                    (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'plan', 'settings', 'streak', 'bestStreak', 'timetableMetadata', 'assistantChat', 'groups', 'planUpgradeDate']) || 
                     isValidUser(incoming())); // Allow full updates or specific field changes

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // 2. Collaborative Groups
    match /groups/{groupId} {
      allow create: if isSignedIn();
      allow get, list, update: if isSignedIn();
      allow delete: if isSignedIn() && existing().adminId == request.auth.uid;
    }
  }
}
